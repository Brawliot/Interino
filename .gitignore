# Manifest: se genera en build/dev según JSON presentes en disco (no commitear listado de R2)
data/public/manifest.json

# Educación CLM — listados por especialidad (grandes)
data/educacion/maestros/*.json
data/educacion/secundaria/*.json
data/educacion/tecnicos-fp/*.json
data/educacion/eoii/*.json
data/educacion/catedraticos-musica/*.json
data/educacion/profesores-musica/*.json
data/educacion/artes-plasticas/*.json
data/educacion/maestros-taller/*.json
data/educacion/fp-singulares/*.json
